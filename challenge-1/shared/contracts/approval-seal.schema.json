{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moei.prototype.local/contracts/approval-seal.schema.json",
  "title": "MOEI Dynamic Approval Seal",
  "type": "object",
  "required": [
    "contractVersion",
    "stampId",
    "caseId",
    "approvedBy",
    "role",
    "action",
    "approvedAt",
    "method",
    "challengeId",
    "payloadHash",
    "status"
  ],
  "properties": {
    "contractVersion": { "const": "approval-seal.v1" },
    "stampId": { "type": "string" },
    "caseId": { "type": "string" },
    "approvedBy": { "type": "string" },
    "role": { "type": "string" },
    "action": { "type": "string" },
    "arAction": { "type": "string" },
    "approvedAt": { "type": "string" },
    "method": { "type": "string" },
    "challengeId": { "type": "string" },
    "payloadHash": { "type": "string" },
    "status": { "type": "string", "enum": ["verified", "revoked", "expired"] }
  },
  "additionalProperties": true
}
