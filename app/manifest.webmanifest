{
  "name": "MOEI Case Cockpit",
  "short_name": "MOEI",
  "description": "Citizen app for submitting and tracking housing arrears rescheduling requests.",
  "start_url": "/app/",
  "scope": "/app/",
  "display": "standalone",
  "background_color": "#050b14",
  "theme_color": "#050b14",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/app/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Start Smart Request",
      "url": "/app/wizard.html",
      "description": "Submit a housing arrears rescheduling request"
    },
    {
      "name": "Track Request",
      "url": "/app/",
      "description": "Track an existing application"
    }
  ]
}
