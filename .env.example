# Copy this file to .env for local testing.
# Do not commit real API keys, access tokens, passwords, or production secrets.

PORT=9710
MOEI_PUBLIC_ORIGIN=http://127.0.0.1:9710

# Optional AI providers.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
CLAUDE_REASONING_MODEL=claude-haiku-4-5-20251001
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# TrustGate adapter configuration.
MOEI_AUTH_PROVIDER_ID=trustgate
MOEI_AUTH_PROVIDER_NAME=TrustGate
MOEI_AUTH_PROVIDER_MODE=external_trust_service
TRUSTGATE_BASE_URL=https://trustgate.sahlabs.me/

# WhatsApp Cloud API integration, optional for local review.
META_APP_ID=
META_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# Twilio voice integration, optional for local review.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_TOKEN=
